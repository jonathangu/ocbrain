<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>com.jonathangu.ocbrain.autopilot.light</string>
  <!--
    DEPRECATED / RETIRED — DO NOT INSTALL OR LOAD.

    This label is retained only so operators can identify and remove an old
    installation. v0.4.1 has no recurring light-autopilot job. The historical
    stage profile remains available only through an explicit manual CLI call.
    There is deliberately no timer and the inert program cannot dispatch work.
  -->
  <key>Disabled</key><true/>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/false</string>
  </array>
  <key>RunAtLoad</key><false/>
</dict>
</plist>
