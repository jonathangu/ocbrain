#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
ROOT="${OCBRAIN_ROOT:-$(cd -- "$SCRIPT_DIR/.." && pwd)}"
DB="${OCBRAIN_DB:-}"
ACTIVE_DB_FILE="${OCBRAIN_ACTIVE_DB_FILE:-$ROOT/data/active-core.path}"
DB_SELECTED_FROM_POINTER=0

# A migration never repoints clients itself. Activation is the separate act of
# writing one absolute database path to this ignored local file.
if [[ -z "$DB" && -r "$ACTIVE_DB_FILE" ]]; then
  IFS= read -r DB < "$ACTIVE_DB_FILE"
  if [[ "$DB" != /* ]]; then
    echo "ocbrain: $ACTIVE_DB_FILE must contain one absolute database path" >&2
    exit 2
  fi
  DB_SELECTED_FROM_POINTER=1
fi
DB="${DB:-$ROOT/data/ocbrain.sqlite}"

if [[ -n "${OCBRAIN_PYTHON:-}" ]]; then
  PYTHON="$OCBRAIN_PYTHON"
elif [[ -x "$ROOT/.venv/bin/python" ]]; then
  PYTHON="$ROOT/.venv/bin/python"
else
  PYTHON="$(command -v python3)"
fi

export PYTHONPATH="$ROOT/src${PYTHONPATH:+:$PYTHONPATH}"
# Keep client-owned stdio transports alive by default. Some MCP hosts do not
# reconnect after a clean idle exit and surface the next call as
# "Transport closed". Operators that need orphan cleanup may still set an
# explicit positive OCBRAIN_MCP_IDLE_TIMEOUT_SECONDS value.
if [[ "$DB_SELECTED_FROM_POINTER" == 1 ]]; then
  exec "$PYTHON" -m ocbrain.cli --db "$DB" mcp --active-db-file "$ACTIVE_DB_FILE" "$@"
fi
exec "$PYTHON" -m ocbrain.cli --db "$DB" mcp "$@"
