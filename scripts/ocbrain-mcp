#!/usr/bin/env bash
set -euo pipefail

ROOT="${OCBRAIN_ROOT:-/Users/guclaw/.openclaw/workspace/ocbrain}"
DB="${OCBRAIN_DB:-$ROOT/data/ocbrain.sqlite}"
PYTHON="${OCBRAIN_PYTHON:-/opt/homebrew/bin/python3.13}"

export PYTHONPATH="$ROOT/src${PYTHONPATH:+:$PYTHONPATH}"
exec "$PYTHON" -m ocbrain.cli --db "$DB" mcp "$@"
